{
  "name": "nk-com",
  "version": "1.0.0",
  "description": "新田菓子舗 公式サイト",
  "private": true,
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@shopify/liquid-html-parser": "^2.9.2",
    "@shopify/prettier-plugin-liquid": "^1.10.3",
    "@tailwindcss/cli": "^4.3.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "prettier-plugin-jinja-template": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/global.css -o ./src/assets/css/global.css",
    "serve:css": "tailwindcss -i ./src/global.css -o ./src/assets/css/global.css --watch",
    "build:site": "eleventy",
    "serve:site": "eleventy --serve",
    "deploy": "bun run-s build:css build:site",
    "serve": "bun run-p serve:css serve:site"
  }
}
