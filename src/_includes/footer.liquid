    <a href="/" class="hover:text-gray-300 transition-colors">ホーム</a>
    <span class="text-gray-700">|</span>
    <a href="/about" class="hover:text-gray-300 transition-colors">新田菓子舗について</a>
    <span class="text-gray-700">|</span>
    <a href="/shops" class="hover:text-gray-300 transition-colors">販売店・取扱店</a>
    <span class="text-gray-700">|</span>
    <a href="/legal" class="hover:text-gray-300 transition-colors">特定商取引法に基づく表記</a>
