<section class="bg-matcha-100 px-8 py-12">
  <h2 class="mb-6 text-xl font-semibold">場所・アクセス</h2>

  <div class="grid gap-4 grid-cols-1 lg:grid-cols-[auto_1fr]">
    <!-- HQ Address -->
    <div>
      <address class="not-italic mb-4 text-sm leading-relaxed">
        <p>〒{{ info.address.zip }}</p>
        <p>
          {{ info.address.pref -}}
          {{- info.address.city -}}
          {{- info.address.street }}
        </p>
        <p>「上長田郵便局」すぐ隣</p>
        <p>駐車場: あり (5台)</p>
      </address>
      <div class="mb-4 text-sm leading-relaxed">
        <p>
          電話番号:
          <span>
            <a
              href="tel:{{ info.tel | remove: ' ' }}"
              class="text-blue-600 underline"
            >
              {{ info.tel }}
            </a>
          </span>
        </p>
        <p>営業時間: {{ info.businessHours }}</p>
        <p>定休日: {{ info.openDays }}</p>
        <p>お支払い方法: 現金のみ</p>
        <blockquote class="text-xs py-2">PayPay・クレジットカード等、電子決済はご利用いただけません。</blockquote>
      </div>
    </div>

    <!-- MapLibre GL JS -->
    <div
      id="map"
      class="min-h-[280px] rounded-lg lg:aspect-[3/2]"
      x-data="mapComponent()"
      x-init="initMap()"
      data-lat="{{ info.latitude }}"
      data-lng="{{ info.longitude }}"
      data-company="{{ info.companyName }}"
      data-pref="{{ info.address.pref }}"
      data-city="{{ info.address.city }}"
      data-street="{{ info.address.street }}"
    ></div>
  </div>

  <!-- Google Maps link -->
  <p>
    <a
      class="p-4 text-blue-600 underline after:content-['_↗']"
      href="https://maps.app.goo.gl/esp86D2EaypwqxibA"
      target="_blank"
      rel="noopener noreferrer"
    >
      Google Mapsで見る
    </a>
  </p>
</section>