<section class="px-4 py-12 max-w-5xl mx-auto">
  <h2 class="mb-8 text-2xl font-semibold text-center">商品</h2>

  {% assign grouped = products.product | group_by: "category" %}

  {% for group in grouped %}
    <div class="mb-12 last:mb-0">
      <h3 class="mb-4 text-lg font-medium text-gray-700 border-b border-gray-200 pb-2">
        {{ group.name }}
      </h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {% for item in group.items %}
          <div class="flex flex-row bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
            <div class="w-1/3 shrink-0 overflow-hidden bg-gray-50">
              <picture>
                <source srcset="{{ item.image | webp }}" type="image/webp">
                <img
                  x-data="image"
                  x-bind:onerror="handleError"
                  src="{{ item.image }}"
                  alt="{{ item.name }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                >
              </picture>
            </div>
            <div class="flex flex-col justify-between p-3 w-2/3">
              <div>
                <h4 class="text-sm font-medium text-gray-900 mb-1">{{ item.name }}</h4>
                {% for variant in item.variant %}
                  <div class="text-xs tabular-nums text-gray-600">
                    {{ variant.price -}} 円 / {{ variant.piece -}}{{ variant.unit }}
                  </div>
                {% endfor %}
              </div>
              <div x-data="{ expanded: false }" class="mt-2">
                <p
                  :class="expanded ? '' : 'line-clamp-3'"
                  @click="expanded = !expanded"
                  class="text-xs text-gray-500 leading-relaxed cursor-pointer select-none"
                >{{ item.description }}</p>
                <button
                  @click="expanded = !expanded"
                  class="text-[10px] text-gray-400 hover:text-gray-600 mt-0.5 cursor-pointer"
                  x-text="expanded ? '閉じる ▲' : 'もっと見る ▼'"
                ></button>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</section>
