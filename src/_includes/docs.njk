<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="{{ eleventy.generator }}" />
    <meta name="description" content="{{ metaDescription or '蒜山高原の特産品を使った洋菓子・和菓子の製造・販売。' }}" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ヒルゼンのお菓子屋 新田菓子舗" />
    <meta property="og:title" content="{{ title }} - ヒルゼンのお菓子屋 新田菓子舗" />
    <meta property="og:description" content="{{ metaDescription or '蒜山高原の特産品を使った洋菓子・和菓子の製造・販売。' }}" />
    <meta property="og:image" content="{{ ogImage or '/assets/img/souffle.jpg' }}" />
    <meta property="og:url" content="{{ page.url | url }}" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title }} - ヒルゼンのお菓子屋 新田菓子舗" />
    <meta name="twitter:description" content="{{ metaDescription or '蒜山高原の特産品を使った洋菓子・和菓子の製造・販売。' }}" />
    <meta name="twitter:image" content="{{ ogImage or '/assets/img/souffle.jpg' }}" />

    <title>{{ title }} - ヒルゼンのお菓子屋 新田菓子舗</title>

    <link rel="stylesheet" href="{{ env.siteUrl }}/assets/css/global.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=LINE+Seed+JP&display=swap"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/jpg" href="/assets/img/ushi_cyan.jpg" />

    <!-- Alpine.js -->
    <script
      src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"
      defer
    ></script>
    <script src="{{ env.siteUrl }}/assets/js/img-onerror.mjs" type="module"></script>

  </head>

  <body>
    <section class="document-container">
      <div class="document-title-column">
        <h1 class="document-title writing-vertical-rl">{{ title }}</h1>
      </div>
      <article class="document-body" aria-label="{{ title }}の本文">
        <div class="document-body-inner">
          {{ content | safe }}
        </div>
      </article>
    </section>
    <div class="flex justify-center mx-auto p-2">
      <a href="/" class="bg-gray-900 p-4 text-center text-white">
        トップページへ戻る
      </a>
    </div>
    {% include 'footer.liquid' %}
  </body>
</html>
